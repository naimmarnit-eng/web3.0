import type { {{Entity}}Repository } from "@/application/ports/{{entity-kebab}}-repository";
import type { Create{{Entity}}Input } from "@/application/dto/{{entity-kebab}}.dto";
import type { {{Entity}} } from "@/domain/entities/{{entity-kebab}}";
import { slugify } from "@/domain/value-objects/slug";

export class Create{{Entity}} {
  constructor(private readonly repo: {{Entity}}Repository) {}

  async execute(input: Create{{Entity}}Input): Promise<{{Entity}}> {
    const item: {{Entity}} = {
      id: crypto.randomUUID(),
      slug: slugify(input.title),
      status: "DRAFT",
      createdAt: new Date(),
      ...input,
    };
